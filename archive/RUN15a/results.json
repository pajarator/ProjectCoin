{
  "experiment": "Bayesian vs Binary Strategy Backtest",
  "date": "2026-03-16",
  "description": "Comparing CoinClaw's binary threshold approach with Bayesian probabilistic decision making",
  
  "data": {
    "source": "ProjectCoin/data_cache",
    "coins": ["DASH", "UNI", "NEAR", "ADA", "LTC", "SHIB", "LINK", "ETH", "BTC", "BNB", "XRP", "SOL", "DOT", "AVAX", "ATOM", "DOGE"],
    "timeframe": "15m",
    "period": "1 year (35,040 bars per coin)",
    "train_test_split": "50% train / 50% test (6 months each)"
  },
  
  "strategies": {
    "binary": {
      "description": "CoinClaw original: z < -1.5, RSI < 40, vol > 1.2x MA",
      "threshold": "hardcoded"
    },
    "bayesian": {
      "description": "Learns P(up | z-score, RSI bin) from training data, enters when P(up) > 60%",
      "threshold": "probabilistic"
    },
    "combined": {
      "description": "Binary signal + Bayesian confirmation (prob_strat > 55%)",
      "threshold": "hybrid"
    }
  },
  
